{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/pages/Validator/verdict.ts",
    "src/pages/Ontology/alignmentBands.ts",
    "src/pages/Graph/graphLayout.ts",
    "src/pages/Graph/glossaryAlignment.ts",
    "src/pages/Graph/complianceGraph.ts",
    "src/pages/Graph/documentsGraph.ts"
  ],
  "reporters": ["clear-text", "progress"],
  "concurrency": 2
}
