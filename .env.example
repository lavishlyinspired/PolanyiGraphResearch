# GraphOS configuration — copy to .env and fill in what you use.
# Everything is optional: with no keys at all, GraphOS runs in deterministic
# mode (schema-derived context + symbolic validation; agent disabled).

# ── LLM provider (pick one; auto-detected in this order) ──────────
# NVIDIA NIM (https://build.nvidia.com)
#NVIDIA_API_KEY=

# OpenAI
#OPENAI_API_KEY=

# Databricks model serving (also used by the ingest command below)
#DATABRICKS_HOST=https://dbc-xxxxxxxx.cloud.databricks.com
#DATABRICKS_TOKEN=
#DATABRICKS_SERVING_ENDPOINT=databricks-meta-llama-3-3-70b-instruct

# Force a provider or disable LLMs entirely: nvidia | openai | databricks | none
#GRAPHOS_LLM_PROVIDER=

# Override models per role
#GRAPHOS_PIPELINE_MODEL=meta/llama-3.1-8b-instruct
#GRAPHOS_AGENT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# ── Databricks (graphos ingest-databricks, connectors) ────────────
#DATABRICKS_WAREHOUSE_ID=
#DATABRICKS_CATALOG=main
#DATABRICKS_SCHEMA=default

# ── Optional graph backends (research/roadmap integrations) ───────
#GRAPHDB_ENDPOINT=http://localhost:7200/
#GRAPHDB_REPOSITORY=fibo
#NEO4J_URI=neo4j://127.0.0.1:7687
#NEO4J_USERNAME=neo4j
#NEO4J_PASSWORD=
